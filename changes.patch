class TestReadmeCodeBlocks:
    """Tests to verify code blocks in README are properly formatted"""
    
    @pytest.fixture(scope="class")
    def readme_content(self):
        """Fixture to load README.md content"""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_bash_code_blocks_have_syntax_highlighting(self, readme_content):
        """Verify bash commands use proper syntax highlighting"""
        # Check for ```bash or ```sh
        bash_blocks = re.findall(r'```bash\n(.*?)```', readme_content, re.DOTALL)
        sh_blocks = re.findall(r'```sh\n(.*?)```', readme_content, re.DOTALL)
        
        assert len(bash_blocks) > 0 or len(sh_blocks) > 0, \
            "README should use ```bash or ```sh for shell commands"
    
    def test_env_code_blocks_present(self, readme_content):
        """Verify environment variables are shown in code blocks"""
        env_blocks = re.findall(r'```(?:env|bash|sh)?\n(.*?)```', readme_content, re.DOTALL)
        
        has_env_content = any('PORT=' in block or 'MONGO_URI=' in block for block in env_blocks)
        assert has_env_content, \
            "README should show environment variables in code blocks"
    
    def test_no_broken_code_blocks(self, readme_content):
        """Verify all code blocks are properly closed"""
        open_blocks = readme_content.count("```")
        assert open_blocks % 2 == 0, \
            f"README has unclosed code blocks (found {open_blocks} backtick groups)"


class TestReadmeLinks:
    """Tests to verify links in README are properly formatted"""
    
    @pytest.fixture(scope="class")
    def readme_content(self):
        """Fixture to load README.md content"""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_internal_links_use_anchors(self, readme_content):
        """Verify internal navigation links use proper anchor format"""
        # Check for table of contents links like [Features](#-features)
        anchor_links = re.findall(r'\[([^\]]+)\]\(#[^\)]+\)', readme_content)
        assert len(anchor_links) > 0, \
            "README should use anchor links for internal navigation"
    
    def test_external_links_use_https(self, readme_content):
        """Verify external links use HTTPS where applicable"""
        # Find all URLs
        urls = re.findall(r'https?://[^\s\)]+', readme_content)
        
        # Check that github and other sensitive sites use HTTPS
        for url in urls:
            if 'github.com' in url or 'shields.io' in url:
                assert url.startswith('https://'), \
                    f"External link should use HTTPS: {url}"


class TestReadmeCompleteness:
    """Tests to verify README covers all major features mentioned in plan"""
    
    @pytest.fixture(scope="class")
    def readme_content(self):
        """Fixture to load README.md content"""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_features_section_complete(self, readme_content):
        """Verify Features section covers all major feature categories"""
        feature_categories = [
            "Authentication",
            "User Management", 
            "Browse",
            "Dashboard",
            "Skill Swap",
            "Admin Panel"
        ]
        
        for category in feature_categories:
            assert category in readme_content, \
                f"Features section should cover {category}"
    
    def test_admin_panel_documented(self, readme_content):
        """Verify Admin Panel features are documented (was incomplete before)"""
        admin_content = readme_content[readme_content.find("Admin"):readme_content.find("Admin")+500] if "Admin" in readme_content else ""
        
        assert "Admin Panel" in readme_content or "admin" in readme_content.lower(), \
            "README should document Admin Panel features"
        
        # Check for admin-specific features
        admin_features = ["Dashboard", "User Management", "Analytics"]
        assert any(feature in admin_content for feature in admin_features), \
            "Admin section should describe specific admin capabilities"


