import pytest
import os
import re
from pathlib import Path

class TestReadmeStructure:
    """Tests to verify README.md structure and content improvements"""
    
    @pytest.fixture(scope="class")
    def readme_content(self):
        """Fixture to load README.md content"""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_readme_file_exists(self):
        """Verify README.md exists in repository root"""
        assert Path("README.md").exists(), "README.md should exist in repository root"
    
    def test_readme_has_title(self, readme_content):
        """Verify README has main title with project name"""
        assert "# 🔁 SkillSwap" in readme_content or "# SkillSwap" in readme_content, \
            "README should have SkillSwap as main title"
    
    def test_readme_has_badges(self, readme_content):
        """Verify README contains status badges"""
        badge_patterns = [
            r"\[\!\[.*\]\(.*shields\.io.*\)\]",  # shields.io badges
            r"\[\!\[License",  # License badge
            r"\[\!\[Node\.js",  # Node version badge
        ]
        assert any(re.search(pattern, readme_content) for pattern in badge_patterns), \
            "README should contain status badges"
    
    def test_readme_has_table_of_contents(self, readme_content):
        """Verify README has Table of Contents section"""
        toc_patterns = [
            r"## 📋 Table of Contents",
            r"\- \[Overview\]",
            r"\- \[Tech Stack\]",
            r"\- \[Features\]",
            r"\- \[Installation",
        ]
        for pattern in toc_patterns:
            assert re.search(pattern, readme_content, re.IGNORECASE), \
                f"README should contain Table of Contents with pattern: {pattern}"
    
    def test_readme_has_tech_stack_section(self, readme_content):
        """Verify README has Tech Stack section with technologies"""
        assert "## 🛠️ Tech Stack" in readme_content, \
            "README should have Tech Stack section"
        
        tech_keywords = ["React", "Node.js", "Express", "MongoDB", "JWT"]
        for tech in tech_keywords:
            assert tech in readme_content, \
                f"README Tech Stack should mention {tech}"
    
    def test_readme_has_installation_section(self, readme_content):
        """Verify README has Installation & Setup section"""
        assert "## 🚀 Installation & Setup" in readme_content, \
            "README should have Installation & Setup section"
        
        # Check for prerequisites
        assert "Prerequisites" in readme_content, \
            "Installation section should list prerequisites"
        
        # Check for code blocks with bash commands
        assert "```bash" in readme_content or "```sh" in readme_content, \
            "Installation section should have bash code blocks"
        
        # Check for npm install commands
        assert "npm install" in readme_content, \
            "Installation section should include npm install commands"
    
    def test_readme_has_environment_variables_section(self, readme_content):
        """Verify README documents environment variables"""
        assert "## 🔐 Environment Variables" in readme_content, \
            "README should have Environment Variables section"
        
        env_vars = ["PORT", "MONGO_URI", "JWT_SECRET", "NODE_ENV"]
        for var in env_vars:
            assert var in readme_content, \
                f"Environment Variables section should document {var}"
        
        # Check for .env.example reference
        assert ".env.example" in readme_content, \
            "README should reference .env.example file"
    
    def test_readme_has_project_structure_section(self, readme_content):
        """Verify README documents project structure"""
        assert "## 📁 Project Structure" in readme_content, \
            "README should have Project Structure section"
        
        # Check for directory tree
        assert "/client" in readme_content and "/server" in readme_content, \
            "Project Structure should show /client and /server directories"
    
    def test_readme_has_usage_section(self, readme_content):
        """Verify README has Usage section with instructions"""
